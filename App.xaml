<Application x:Class="IndustrialMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:IndustrialMonitor.ViewModels"
             xmlns:views="clr-namespace:IndustrialMonitor.Views"
             xmlns:conv="clr-namespace:IndustrialMonitor.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- HandyControl 全局皮肤 + 主题 -->
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 自定义转换器 -->
            <conv:AlarmTypeColorConverter x:Key="AlarmTypeColor"/>
            <conv:AlarmThresholdConverter x:Key="AlarmThreshold"/>

            <!-- ViewModel → View 映射 -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DeviceManagementViewModel}">
                <views:DeviceManagementView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MonitoringViewModel}">
                <views:MonitoringView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AlarmCenterViewModel}">
                <views:AlarmCenterView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
                <views:HistoryView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
