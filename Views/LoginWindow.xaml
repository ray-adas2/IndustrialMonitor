<Window x:Class="IndustrialMonitor.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工业监控平台 - 登录"
        Height="460" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#F1F5F9">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Margin="20,20,20,0" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="🏭" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="工业设备监控平台" FontSize="16" FontWeight="Bold"
                               Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <TextBlock Text="请登录以继续" FontSize="12"
                               Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 错误提示 — 固定高度防止布局抖动 -->
                <Border Grid.Row="1" CornerRadius="6" Padding="8,6" Margin="0,0,0,10" Height="36">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Background" Value="#FEE2E2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="12"
                               TextAlignment="Center" TextWrapping="Wrap"/>
                </Border>

                <TextBlock Grid.Row="2" Text="用户名" FontSize="13" Foreground="#475569" Margin="0,0,0,4"/>
                <TextBox Grid.Row="3" x:Name="UsernameBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="10,7" Margin="0,0,0,10"
                         Background="#F8FAFC" BorderBrush="#CBD5E1"/>

                <TextBlock Grid.Row="4" Text="密码" FontSize="13" Foreground="#475569" Margin="0,0,0,4"/>
                <PasswordBox Grid.Row="5" x:Name="PasswordBox"
                             FontSize="14" Padding="10,7" Margin="0,0,0,16"
                             Background="#F8FAFC" BorderBrush="#CBD5E1"
                             KeyDown="PasswordBox_KeyDown"/>
            </Grid>
        </Border>

        <Button Grid.Row="1" Content="登 录" FontSize="15" FontWeight="Bold"
                Foreground="White" Height="44" Margin="20,16,20,10"
                Background="#1E293B" BorderThickness="0" Click="LoginButton_Click" Cursor="Hand"/>
    </Grid>
</Window>
