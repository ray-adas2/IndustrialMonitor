<UserControl x:Class="IndustrialMonitor.Views.MonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000">
    <UserControl.Resources>
        <Storyboard x:Key="AlarmFlashing">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.2" Duration="0:0:0.5"
                             AutoReverse="True" RepeatBehavior="Forever" />
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 设备状态条 -->
        <Border Background="White" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#10B981"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedDevice.IsAlarming}" Value="True">
                                    <Setter Property="Fill" Value="#EF4444"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Storyboard="{StaticResource AlarmFlashing}" x:Name="ActiveAlarmFlashing"/>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="ActiveAlarmFlashing"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="温度:" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding SelectedDevice.LatestTemperature}" Foreground="#EF4444" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock Text="压力:" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding SelectedDevice.LatestPressure}" Foreground="#3B82F6" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock Text="设备:" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding SelectedDevice.DeviceId}" Foreground="#1E293B" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock Text="在线:" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Devices.Count}" Foreground="#10B981" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- 设备操作 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
            <Button Content="➕ 添加新设备" Command="{Binding AddDeviceCommand}"
                    Background="#10B981" Foreground="White" FontWeight="Bold"
                    Padding="10,4" Margin="0,0,5,0" BorderThickness="0"/>
            <Button Content="✕ 移除当前设备" Command="{Binding RemoveDeviceCommand}"
                    CommandParameter="{Binding SelectedDevice}"
                    Background="#EF4444" Foreground="White" FontWeight="Bold"
                    Padding="10,4" BorderThickness="0"/>
        </StackPanel>

        <!-- 报警消息条 -->
        <Border Grid.Row="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E2E8F0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedDevice.IsAlarming}" Value="True">
                            <Setter Property="Background" Value="#FEE2E2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding SelectedDevice.AlarmMessage}"
                       HorizontalAlignment="Center" FontWeight="Bold" FontSize="14">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#334155"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedDevice.IsAlarming}" Value="True">
                                <Setter Property="Foreground" Value="#DC2626"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <!-- 图表区 -->
        <TabControl Grid.Row="2" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
                    Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="5,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📟 "/>
                            <TextBlock Text="{Binding DeviceId}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="📈 实时温度波动曲线" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,10"/>
                                <lvc:CartesianChart Grid.Row="1" Series="{Binding TemperatureSeries}" Sections="{Binding TemperatureSections}"/>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="📉 实时压力波动曲线" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,10"/>
                                <lvc:CartesianChart Grid.Row="1" Series="{Binding PressureSeries}" Sections="{Binding PressureSections}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- 报警历史 -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📋 历史报警记录日志" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,5"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding AlarmHistory}" AutoGenerateColumns="False"
                          IsReadOnly="True" GridLinesVisibility="Horizontal"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="编号" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="设备号" Binding="{Binding DeviceId}" Width="90"/>
                        <DataGridTextColumn Header="类型" Binding="{Binding AlarmType}" Width="110"/>
                        <DataGridTextColumn Header="峰值" Binding="{Binding MaxValue, StringFormat={}{0:F2}}" Width="80"/>
                        <DataGridTextColumn Header="阈值" Binding="{Binding Threshold, StringFormat={}{0:F2}}" Width="80"/>
                        <DataGridTextColumn Header="开始时间" Binding="{Binding StartTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="160"/>
                        <DataGridTextColumn Header="结束时间" Binding="{Binding EndTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 控制按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="▶ 开始实时监控" Command="{Binding SelectedDevice.StartCommand}"
                    Width="160" Height="36" Margin="0,0,20,0"
                    Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="⏹ 停止实时监控" Command="{Binding SelectedDevice.StopCommand}"
                    Width="160" Height="36"
                    Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</UserControl>
