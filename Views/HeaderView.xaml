<UserControl x:Class="IndustrialMonitor.Views.HeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="56" d:DesignWidth="1200">
    <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
        <Grid Margin="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- 面包屑 -->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>  <!-- 右侧信息 -->
            </Grid.ColumnDefinitions>

            <!-- 面包屑导航 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding Breadcrumb}" FontSize="13"
                           Foreground="#64748B" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 右侧状态信息 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- 系统状态指示灯 -->
                <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0"/>
                <TextBlock Text="系统运行正常" FontSize="12" Foreground="#64748B"
                           Margin="0,0,20,0" VerticalAlignment="Center"/>

                <!-- 分隔线 -->
                <Border Width="1" Height="20" Background="#E2E8F0" Margin="0,0,16,0"/>

                <!-- 当前时间 -->
                <TextBlock x:Name="ClockText" Text="2026-07-20 14:30:00" FontSize="12"
                           Foreground="#64748B" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
