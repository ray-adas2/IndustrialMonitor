<UserControl x:Class="IndustrialMonitor.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📜 历史记录" FontSize="24" FontWeight="Bold"
                   Foreground="#1E293B" Margin="0,0,0,16"/>

        <!-- 筛选栏 -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <WrapPanel>
                <TextBlock Text="开始日期:" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker SelectedDate="{Binding StartDate}" Width="140" Margin="0,0,16,0"/>
                <TextBlock Text="结束日期:" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker SelectedDate="{Binding EndDate}" Width="140" Margin="0,0,16,0"/>
                <TextBlock Text="设备:" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox ItemsSource="{Binding DeviceFilters}" SelectedItem="{Binding SelectedDeviceFilter}"
                          Width="100" Margin="0,0,12,0"/>
                <Button Content="🔍 查询" Command="{Binding QueryCommand}" Background="#3B82F6"
                        Foreground="White" Padding="12,4" BorderThickness="0" Margin="0,0,8,0"/>
                <Button Content="🔄 刷新" Command="{Binding RefreshCommand}" Background="#10B981"
                        Foreground="White" Padding="12,4" BorderThickness="0"/>
            </WrapPanel>
        </Border>

        <!-- 摘要条 -->
        <Border Grid.Row="2" Background="#F0F9FF" CornerRadius="6" Padding="10,6" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊 " FontSize="13"/>
                <TextBlock Text="{Binding SummaryText}" FontSize="13" Foreground="#1E40AF"/>
                <TextBlock Text="{Binding PageInfo}" FontSize="12" Foreground="#64748B" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 数据表格 -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid Grid.Row="0" ItemsSource="{Binding PagedRecords}" AutoGenerateColumns="False"
                          IsReadOnly="True" GridLinesVisibility="Horizontal"
                          Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="编号" Binding="{Binding Id}" Width="50" MinWidth="40"/>
                        <DataGridTextColumn Header="设备" Binding="{Binding DeviceId}" Width="80" MinWidth="60"/>
                        <DataGridTextColumn Header="类型" Binding="{Binding AlarmType}" Width="110" MinWidth="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="{Binding AlarmType, Converter={StaticResource AlarmTypeColor}}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="峰值" Binding="{Binding MaxValue, StringFormat={}{0:F2}}" Width="65" MinWidth="50"/>
                        <DataGridTemplateColumn Header="阈值详情" Width="180" MinWidth="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource AlarmThreshold}">
                                                <Binding Path="AlarmType"/>
                                                <Binding Path="Threshold"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="开始时间" Binding="{Binding StartTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="155" MinWidth="120"/>
                        <DataGridTextColumn Header="结束时间" Binding="{Binding EndTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="155" MinWidth="120"/>
                    </DataGrid.Columns>
                </DataGrid>
                <!-- 分页 + 跳转 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Content="◀◀" Command="{Binding FirstPageCommand}" Padding="6,3" Margin="0,0,4,0"
                            Background="#3B82F6" Foreground="White" BorderThickness="0" FontSize="11"/>
                    <Button Content="◀" Command="{Binding PrevPageCommand}" Padding="6,3" Margin="0,0,4,0"
                            Background="#3B82F6" Foreground="White" BorderThickness="0" FontSize="11"/>
                    <TextBlock Text="{Binding PageInfo}" FontSize="12" Foreground="#64748B" Width="160" TextAlignment="Center"/>
                    <Button Content="▶" Command="{Binding NextPageCommand}" Padding="6,3" Margin="4,0,0,0"
                            Background="#3B82F6" Foreground="White" BorderThickness="0" FontSize="11"/>
                    <Button Content="▶▶" Command="{Binding LastPageCommand}" Padding="6,3" Margin="4,0,0,0"
                            Background="#3B82F6" Foreground="White" BorderThickness="0" FontSize="11"/>
                    <TextBlock Text="跳转:" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" Margin="10,0,4,0"/>
                    <TextBox x:Name="JumpBox" Width="40" Height="22" FontSize="12" VerticalContentAlignment="Center" Margin="0,0,4,0"/>
                    <Button Content="Go" Command="{Binding JumpPageCommand}"
                            CommandParameter="{Binding Text, ElementName=JumpBox}"
                            Padding="6,3" Background="#10B981" Foreground="White" BorderThickness="0" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
