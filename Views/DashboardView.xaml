<UserControl x:Class="IndustrialMonitor.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">
            <!-- 页面标题 -->
            <TextBlock Text="📊 首页总览" FontSize="24" FontWeight="Bold"
                       Foreground="#1E293B" Margin="0,0,0,24"/>

            <!-- 统计卡片行 -->
            <UniformGrid Columns="4" Rows="1" Margin="0,0,0,24">
                <hc:Card Margin="4" Background="White">
                    <StackPanel Margin="16">
                        <TextBlock Text="设备总数" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="{Binding TotalDevices}" FontSize="36" FontWeight="Bold"
                                   Foreground="#3B82F6" Margin="0,4,0,0"/>
                        <TextBlock Text="台已注册" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                    </StackPanel>
                </hc:Card>
                <hc:Card Margin="4" Background="White">
                    <StackPanel Margin="16">
                        <TextBlock Text="在线设备" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="{Binding OnlineDevices}" FontSize="36" FontWeight="Bold"
                                   Foreground="#10B981" Margin="0,4,0,0"/>
                        <TextBlock Text="台运行中" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                    </StackPanel>
                </hc:Card>
                <hc:Card Margin="4" Background="White">
                    <StackPanel Margin="16">
                        <TextBlock Text="当前报警" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="{Binding AlarmCount}" FontSize="36" FontWeight="Bold"
                                   Foreground="#EF4444" Margin="0,4,0,0"/>
                        <TextBlock Text="条待处理" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                    </StackPanel>
                </hc:Card>
                <hc:Card Margin="4" Background="White">
                    <StackPanel Margin="16">
                        <TextBlock Text="运行中" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="{Binding RunningCount}" FontSize="36" FontWeight="Bold"
                                   Foreground="#8B5CF6" Margin="0,4,0,0"/>
                        <TextBlock Text="台实时监控" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                    </StackPanel>
                </hc:Card>
            </UniformGrid>

            <!-- 系统概览区域 -->
            <hc:Card Margin="4,0" Background="White" Padding="24">
                <StackPanel>
                    <TextBlock Text="📋 平台运行概览" FontSize="16" FontWeight="Bold"
                               Foreground="#1E293B" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 设备状态分布 -->
                        <Border Grid.Column="0" Padding="8">
                            <StackPanel>
                                <TextBlock Text="设备状态分布" FontSize="14" Foreground="#64748B" Margin="0,0,0,8"/>
                                <StackPanel Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="在线设备" FontSize="13" Foreground="#475569" VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding OnlinePercent}" Height="8" Foreground="#10B981" Margin="8,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding OnlinePercent, StringFormat={}{0:F0}%}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="报警设备" FontSize="13" Foreground="#475569" VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding AlarmPercent}" Height="8" Foreground="#EF4444" Margin="8,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding AlarmPercent, StringFormat={}{0:F0}%}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 快捷操作 -->
                        <Border Grid.Column="1" Padding="8">
                            <StackPanel>
                                <TextBlock Text="快捷操作" FontSize="14" Foreground="#64748B" Margin="0,0,0,8"/>
                                <Button Content="🖥 查看设备列表" Margin="0,4"
                                        Background="#3B82F6" Foreground="White" BorderThickness="0" Padding="8,4"/>
                                <Button Content="📈 打开实时监控" Margin="0,4"
                                        Background="#10B981" Foreground="White" BorderThickness="0" Padding="8,4"/>
                                <Button Content="⚠ 查看报警中心" Margin="0,4"
                                        Background="#EF4444" Foreground="White" BorderThickness="0" Padding="8,4"/>
                            </StackPanel>
                        </Border>

                        <!-- 系统信息 -->
                        <Border Grid.Column="2" Padding="8">
                            <StackPanel>
                                <TextBlock Text="系统信息" FontSize="14" Foreground="#64748B" Margin="0,0,0,8"/>
                                <TextBlock Text=".NET 8 + WPF" FontSize="13" Foreground="#475569" Margin="0,2"/>
                                <TextBlock Text="HandyControl 3.5.1" FontSize="13" Foreground="#475569" Margin="0,2"/>
                                <TextBlock Text="LiveCharts2" FontSize="13" Foreground="#475569" Margin="0,2"/>
                                <TextBlock Text="SQLite 持久化" FontSize="13" Foreground="#475569" Margin="0,2"/>
                                <TextBlock Text="MVVM + DI 架构" FontSize="13" Foreground="#475569" Margin="0,2"/>
                                <TextBlock Text="配置热重载" FontSize="13" Foreground="#475569" Margin="0,2"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </hc:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
