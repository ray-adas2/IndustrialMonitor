<Window x:Class="IndustrialMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:IndustrialMonitor.Views"
        mc:Ignorable="d"
        Title="工业监控平台" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F1F5F9">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <views:HeaderView Grid.Row="0" DataContext="{Binding}" />

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧导航栏 -->
            <views:SidebarView Grid.Column="0" DataContext="{Binding Navigation}" />

            <!-- 中央工作区：PageHost -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                          Background="#F1F5F9">
                <ContentControl Content="{Binding CurrentPage}" Margin="16"/>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#0F172A" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Industrial Monitor v1.0" FontSize="11" Foreground="#64748B"/>
                    <TextBlock Text=" | .NET 8 + WPF + LiveCharts2" FontSize="11" Foreground="#64748B"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="#10B981" Margin="0,0,4,0"/>
                    <TextBlock Text="系统运行中" FontSize="11" Foreground="#94A3B8"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
